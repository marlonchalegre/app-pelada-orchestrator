{
  "name": "e2e-tests",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "playwright test",
    "env:up": "docker-compose -f ../docker-compose.yml up -d --build",
    "env:down": "docker-compose -f ../docker-compose.yml down -v",
    "db:backup": "cp ../api-peladaapp/peladaapp.db* /tmp/ 2>/dev/null || true",
    "db:restore": "rm -f ../api-peladaapp/peladaapp.db* && cp /tmp/peladaapp.db* ../api-peladaapp/ 2>/dev/null || true",
    "db:clean": "rm -f ../api-peladaapp/peladaapp.db*",
    "wait-for-backend": "node scripts/wait-for-backend.js",
    "test:debug": "playwright test --debug",
    "test:e2e": "npm run db:backup && npm run env:down && npm run db:clean && npm run env:up && npm run wait-for-backend && (npm run test || (EXIT_CODE=$?; echo 'Test failed, capturing logs...'; docker compose -f ../docker-compose.yml logs > test-results/docker-error.log; npm run env:down; npm run db:restore; exit $EXIT_CODE)); npm run env:down && npm run db:restore"
  },

  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
