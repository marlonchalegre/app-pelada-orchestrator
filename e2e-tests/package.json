{
  "name": "e2e-tests",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "playwright test",
    "env:up": "docker-compose -f ../docker-compose.yml up -d --build",
    "env:down": "docker-compose -f ../docker-compose.yml down -v",
    "db:backup": "echo 'Postgres backup not implemented' || true",
    "db:restore": "echo 'Postgres restore not implemented' || true",
    "db:clean": "rm -rf ../pgdata",
    "wait-for-backend": "node scripts/wait-for-backend.js",
    "test:debug": "playwright test --debug",
    "test:e2e": "npm run env:down && npm run db:clean && npm run env:up && npm run wait-for-backend && (npm run test || (EXIT_CODE=$?; echo 'Test failed, capturing logs...'; docker compose -f ../docker-compose.yml logs > test-results/docker-error.log; npm run env:down; exit $EXIT_CODE)); npm run env:down"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "25.6.0",
    "ts-node": "^10.9.2",
    "typescript": "6.0.3"
  }
}
